# ============================================
# Italian Learning Platform - ENV Variables
# ============================================

# --- PostgreSQL (Render) ---
DB_HOST=your-db-host.oregon-postgres.render.com
DB_PORT=5432
DB_NAME=italian_learning_db
DB_USER=italian_learning_db_user
DB_PASSWORD=your-db-password

# --- JWT ---
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Google Cloud (TTS + Drive + YouTube) ---
GOOGLE_TTS_API_KEY=AIza...
GOOGLE_API_KEY=AIza...

# --- Server ---
PORT=3001
NODE_ENV=production
